# Gmail account used to send form notifications. Never expose these as VITE_* variables.
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Optional: deliver notifications to a different inbox.
FORM_RECIPIENT_EMAIL=your-address@gmail.com

# Optional: a long random value used to sign anti-spam cookies.
FORM_SECRET=replace-with-a-long-random-value
