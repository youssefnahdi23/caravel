{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/create-website", "destination": "/create-website.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
